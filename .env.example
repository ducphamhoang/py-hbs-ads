# SharePoint Configuration (required for SharePoint commands)
SP_SITE_URL=https://your-tenant-my.sharepoint.com/personal/your_path
SP_TENANT_ID=your-tenant.onmicrosoft.com

# SharePoint base paths — V1-199 are directly under the root video folder (no 100+ folder)
SP_BASE_PATH_ROOT=Documents/Your/Path/02.1 - Video
SP_BASE_PATH_V100=Documents/Your/Path/02.1 - Video
SP_BASE_PATH_V200=Documents/Your/Path/02.1 - Video/2 - V200+
SP_BASE_PATH_V300=Documents/Your/Path/02.1 - Video/3 - V300+
SP_BASE_PATH_V400=Documents/Your/Path/02.1 - Video/4 - V400+

# Default base path (used when --target not specified)
SP_BASE_PATH=Documents/Your/Path/02.1 - Video/4 - V400+

# Teams / Microsoft Graph Configuration (optional)
# The Entra app used by `m365 login` must already have delegated Graph permissions.
M365_TENANT_ID=your-tenant.onmicrosoft.com
M365_TEAMS_APP_ID=00000000-0000-0000-0000-000000000000
HBS_ADS_TEAMS_REQUIRED_SCOPES=User.Read,Chat.ReadBasic,Chat.Read,ChatMessage.Send
# Temporary/manual Graph Explorer token bridge for Teams tests.
# Do not commit real tokens. Access tokens expire quickly.
# HBS_ADS_GRAPH_ACCESS_TOKEN=

# Shared library root — persistent asset library across all jobs
# SharePoint downloads land here under raw/
VIDEO_LIBRARY_ROOT=~/work/video-library

# Optional: Alternative base paths for different variants
# SP_BASE_PATH_V200=Documents/V200+
# SP_BASE_PATH_V300=Documents/V300+
# SP_BASE_PATH_V400=Documents/V400+

# Discord Notifications (optional)
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR/WEBHOOK

# AI Provider (optional)
GEMINI_API_KEY=your-api-key
